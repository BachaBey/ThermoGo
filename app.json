{
  "expo": {
    "name": "ThermoGo",
    "slug": "thermogo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-nav.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#006C95"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thermogo.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-nav.png",
        "backgroundColor": "#006C95"
      },
      "package": "com.thermogo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon-nav.png",
      "name": "ThermoGo",
      "shortName": "ThermoGo",
      "themeColor": "#006C95",
      "backgroundColor": "#006C95",
      "description": "Monitor your temperature and humidity sensors in real time."
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ThermoGo to use the camera to scan device QR codes."
        }
      ]
    ]
  }
}
